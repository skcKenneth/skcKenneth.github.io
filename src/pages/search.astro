---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Search" description="Search research, projects, writing, and teaching materials."><header class="page-head"><div class="container"><p class="eyebrow">Search</p><h1>Find an idea, method, or project.</h1><p class="lead">The index covers research, projects, writing, and teaching. Redirect and duplicate pages are excluded.</p></div></header><section class="section"><div class="container measure"><label for="search-input"><strong>Search the site</strong></label><input id="search-input" type="search" placeholder="Try “routing”, “dengue”, or “sensitivity”" style="display:block;width:100%;padding:.8rem;margin:.5rem 0 1rem;font:inherit;border:1px solid #8b9690"/><p class="small" id="search-status" aria-live="polite">Type at least two characters.</p><div id="search-results"></div><noscript><p>Search requires JavaScript. Use the <a href="/projects/">project filters</a> or <a href="/writing/">writing index</a>.</p></noscript></div></section>
<script is:inline>
const input=document.querySelector('#search-input'),results=document.querySelector('#search-results'),status=document.querySelector('#search-status');let pagefind;
const typeFor=url=>url.startsWith('/projects/')?'Project':url.startsWith('/research/')?'Research':url.startsWith('/teaching/')?'Teaching':'Writing';
input.addEventListener('input',async()=>{const q=input.value.trim();if(q.length<2){results.innerHTML='';status.textContent='Type at least two characters.';return}status.textContent='Searching…';try{pagefind??=await import('/pagefind/pagefind.js');const search=await pagefind.search(q);const data=await Promise.all(search.results.slice(0,20).map(r=>r.data()));status.textContent=`${search.results.length} result${search.results.length===1?'':'s'}`;results.innerHTML=data.map(r=>`<article class="card" style="border-top-width:1px"><p class="eyebrow">${typeFor(new URL(r.url,location.origin).pathname)}</p><h2 style="font-size:1.5rem"><a href="${r.url}">${r.meta.title}</a></h2><p>${r.excerpt}</p></article>`).join('')||'<p>No matching pages.</p>'}catch(e){status.textContent=location.hostname==='localhost'?'Search is generated after a production build. Run npm run build, then npm run preview.':'Search index could not be loaded.';}});
</script></BaseLayout>
