---
import { getCollection } from "astro:content"; import BaseLayout from "../../layouts/BaseLayout.astro"; import ProjectCard from "../../components/ProjectCard.astro";
const projects=(await getCollection("projects",({data})=>!data.draft)).sort((a,b)=>b.data.year-a.data.year);
const unique=(values:string[])=>[...new Set(values)].sort(); const topics=unique(projects.flatMap(p=>p.data.topics)); const statuses=unique(projects.map(p=>p.data.status)); const methods=unique(projects.flatMap(p=>p.data.methods));
---
<BaseLayout title="Projects" description="Filterable mathematical modeling projects with explicit status, methods, data, code, and limitations." type="Projects"><header class="page-head"><div class="container"><p class="eyebrow">Projects</p><h1>Models with their evidence attached.</h1><p class="lead">Filter by topic, maturity, method, availability, and student suitability. Status describes the current evidence—not ambition.</p></div></header>
<section class="section"><div class="container"><form class="filter-bar" id="filters" aria-label="Project filters">
<label>Topic<select name="topic"><option value="">All topics</option>{topics.map(v=><option>{v}</option>)}</select></label><label>Status<select name="status"><option value="">All statuses</option>{statuses.map(v=><option>{v}</option>)}</select></label><label>Method<select name="method"><option value="">All methods</option>{methods.map(v=><option>{v}</option>)}</select></label><label>Availability<select name="availability"><option value="">Any</option><option value="code">Code available</option><option value="data">Data available</option><option value="student">Student-suitable</option></select></label>
</form><p class="small" aria-live="polite" id="result-count">{projects.length} projects</p><div class="grid" id="project-grid">{projects.map(p=><ProjectCard project={p} />)}</div><p class="empty" id="empty" hidden>No projects match all selected filters.</p></div></section>
<script is:inline>
const form=document.querySelector('#filters');const cards=[...document.querySelectorAll('[data-project-card]')];const count=document.querySelector('#result-count');const empty=document.querySelector('#empty');
const apply=()=>{const values=Object.fromEntries(new FormData(form).entries());let visible=0;cards.forEach(card=>{const ok=(!values.topic||card.dataset.topic.includes(values.topic))&&(!values.status||card.dataset.status===values.status)&&(!values.method||card.dataset.method.includes(values.method))&&(!values.availability||card.dataset[values.availability]==='true');card.hidden=!ok;if(ok)visible++;});count.textContent=`${visible} project${visible===1?'':'s'}`;empty.hidden=visible!==0;const query=new URLSearchParams(Object.entries(values).filter(([,v])=>v));history.replaceState(null,'',`${location.pathname}${query.size?'?'+query:''}`)};
const params=new URLSearchParams(location.search);for(const el of form.elements){if(el.name&&params.has(el.name))el.value=params.get(el.name)}form.addEventListener('change',apply);apply();
</script></BaseLayout>
