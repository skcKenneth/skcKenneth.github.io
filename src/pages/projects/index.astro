---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import scienceProjects from "../../data/generated/science-projects.json";

const curated = await getCollection("projects", ({ data }) => !data.draft);
const curatedSlugs = new Set(curated.map((project) => project.data.slug));
const catalogue = scienceProjects.filter((project) => !curatedSlugs.has(project.slug));
const projects: any[] = [...curated, ...catalogue].sort((a: any, b: any) => {
  const aYear = a.data?.year ?? a.year;
  const bYear = b.data?.year ?? b.year;
  const aFeatured = a.data?.featured ?? a.featured;
  const bFeatured = b.data?.featured ?? b.featured;
  return Number(bFeatured) - Number(aFeatured) || bYear - aYear;
});
const unique = (values: string[]) => [...new Set(values)].sort();
const topics = unique(projects.flatMap((project: any) => project.data?.topics ?? project.topics ?? []));
const statuses = unique(projects.map((project: any) => project.data?.status ?? project.status));
const methods = unique(projects.flatMap((project: any) => project.data?.methods ?? project.methods ?? []));
---
<BaseLayout title="Projects" description="Curated research catalogue with separate editorial and inventory-level evidence labels." type="Projects">
  <header class="page-head"><div class="container">
    <p class="eyebrow">Research catalogue</p>
    <h1>Every technical project, with its evidence level visible.</h1>
    <p class="lead">All {projects.length} catalogue entries are represented. {curated.length} have full editorial overviews; the remainder expose a high-level inventory without publishing notebooks, raw notes, or private source material.</p>
  </div></header>
  <section class="section"><div class="container">
    <div class="notice"><strong>Two evidence levels.</strong> Editorial projects explain reviewed outputs, methods, and limitations. Catalogue entries record what exists in the private technical workspace but make no claim that the work has been scientifically validated.</div>
    <form class="filter-bar" id="filters" aria-label="Project filters">
      <label>Topic<select name="topic"><option value="">All topics</option>{topics.map((value) => <option>{value}</option>)}</select></label>
      <label>Status<select name="status"><option value="">All statuses</option>{statuses.map((value) => <option>{value}</option>)}</select></label>
      <label>Method<select name="method"><option value="">All methods</option>{methods.map((value) => <option>{value}</option>)}</select></label>
      <label>Availability<select name="availability"><option value="">Any</option><option value="code">Code available</option><option value="data">Data listed</option><option value="student">Student-suitable</option></select></label>
    </form>
    <p class="small" aria-live="polite" id="result-count">{projects.length} projects</p>
    <div class="grid" id="project-grid">{projects.map((project) => <ProjectCard project={project} />)}</div>
    <p class="empty" id="empty" hidden>No projects match all selected filters.</p>
  </div></section>
  <script is:inline>
    const form=document.querySelector('#filters');const cards=[...document.querySelectorAll('[data-project-card]')];const count=document.querySelector('#result-count');const empty=document.querySelector('#empty');
    const apply=()=>{const values=Object.fromEntries(new FormData(form).entries());let visible=0;cards.forEach(card=>{const ok=(!values.topic||card.dataset.topic.includes(values.topic))&&(!values.status||card.dataset.status===values.status)&&(!values.method||card.dataset.method.includes(values.method))&&(!values.availability||card.dataset[values.availability]==='true');card.hidden=!ok;if(ok)visible++;});count.textContent=`${visible} project${visible===1?'':'s'}`;empty.hidden=visible!==0;const query=new URLSearchParams(Object.entries(values).filter(([,value])=>value));history.replaceState(null,'',`${location.pathname}${query.size?'?'+query:''}`)};
    const params=new URLSearchParams(location.search);for(const element of form.elements){if(element.name&&params.has(element.name))element.value=params.get(element.name)}form.addEventListener('change',apply);apply();
  </script>
</BaseLayout>
