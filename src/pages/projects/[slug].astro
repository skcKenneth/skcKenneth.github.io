---
import { getCollection, render } from "astro:content"; import BaseLayout from "../../layouts/BaseLayout.astro"; import StatusBadge from "../../components/StatusBadge.astro"; import Figure from "../../components/Figure.astro";
export async function getStaticPaths(){return (await getCollection("projects",({data})=>!data.draft)).map(entry=>({params:{slug:entry.data.slug},props:{entry}}));}
const {entry}=Astro.props; const {Content}=await render(entry); const d=entry.data;
---
<BaseLayout title={d.title} description={d.summary} image={d.heroImage} type="Projects"><header class="page-head"><div class="container"><p class="eyebrow">Project overview</p><h1>{d.title}</h1><p class="lead">{d.researchQuestion}</p><div class="meta-line"><StatusBadge status={d.status}/><span>Updated {d.lastUpdated.toLocaleDateString("en-GB",{dateStyle:"medium"})}</span></div></div></header>
<div class="container content-shell"><aside><dl class="metadata"><div><dt>Status</dt><dd>{d.status}</dd></div><div><dt>Period</dt><dd>{d.period||d.year}</dd></div><div><dt>Methods</dt><dd>{d.methods.join(" · ")}</dd></div><div><dt>Code</dt><dd>{d.codeAvailable?"Available":"Not listed"}</dd></div><div><dt>Data</dt><dd>{d.dataType||"Not specified"}</dd></div></dl><div class="actions">{d.technicalUrl&&<a class="button" href={d.technicalUrl}>Technical article</a>}{d.repositoryUrl&&<a class="button secondary" href={d.repositoryUrl}>View code</a>}{d.teachingUrl&&<a class="button secondary" href={d.teachingUrl}>Teaching material</a>}</div></aside>
<article class="prose">{d.heroImage&&<Figure src={d.heroImage} alt={`Technical figure from ${d.title}`} caption="A generated research figure synchronized from ScienceProject. The original aspect ratio and labels are preserved." source={d.technicalUrl}/>}<Content />
<h2>Key findings</h2><ul>{d.keyFindings.map(x=><li>{x}</li>)}</ul><h2>Limitations</h2><div class="notice"><ul>{d.limitations.map(x=><li>{x}</li>)}</ul></div><h2>Technical record</h2><p>The detailed source, calculations, generated figures, and reproduction instructions remain in ScienceProject. <a href={d.technicalUrl}>Open the technical project</a>.</p><h2>Version history</h2><p><strong>{d.lastUpdated.toISOString().slice(0,10)}</strong> — Curated project overview reviewed against repository evidence.</p></article></div></BaseLayout>
