---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
const projects = (await getCollection("projects", ({data}) => data.featured && !data.draft)).sort((a,b)=>b.data.year-a.data.year);
const research = await getCollection("research", ({data}) => data.featured && !data.draft);
const writing = (await getCollection("writing", ({data}) => data.featured && !data.draft)).sort((a,b)=>(b.data.date?.valueOf()||0)-(a.data.date?.valueOf()||0));
---
<BaseLayout title="Mathematical models for real systems" description="Kenneth Cheng: mathematical modeling research, teaching, computational experiments, and student research pathways.">
  <section class="hero"><div class="container hero-grid">
    <div><p class="eyebrow">Kenneth Cheng · Macau</p><h1>Mathematical models for real systems.</h1><p class="lead">Research, education, and computational experiments across cities, infrastructure, environment, and learning.</p><div class="actions"><a class="button" href="/research/">Explore Research</a><a class="button secondary" href="/teaching/">Teaching Materials</a></div></div>
    <figure class="hero-figure"><img src="/science/accessible-multimodal-routing/network.png" alt="Multi-layer Gongbei transport network with connected pedestrian, bus, rail, and taxi nodes" width="900" height="680" fetchpriority="high"/><figcaption>Multilayer network used in the accessible-routing study. Approved through the ScienceProject <code>figures/publish/</code> directory; axes and network structure are preserved.</figcaption></figure>
  </div></section>
  <section class="section"><div class="container"><div class="section-head"><div><p class="eyebrow">Current themes</p><h2>Research programmes</h2></div><p>Projects are grouped by the questions and methods that connect them, rather than by publication date.</p></div><div class="grid">{research.map(item=><article class="card"><p class="eyebrow">{item.data.programme}</p><h3><a class="title-link" href={`/research/${item.data.slug}/`}>{item.data.title}</a></h3><p>{item.data.summary}</p></article>)}</div></div></section>
  <section class="section"><div class="container"><div class="section-head"><div><p class="eyebrow">Selected research</p><h2>Evidence before volume</h2></div><p>A small set of projects with reviewed figures, explicit assumptions, and visible limitations. Detailed calculations and source materials are maintained privately.</p></div><div class="grid">{projects.slice(0,4).map(item=><ProjectCard project={item} wide />)}</div><div class="actions"><a class="button secondary" href="/projects/">Browse all projects</a></div></div></section>
  <section class="section"><div class="container"><div class="section-head"><div><p class="eyebrow">Teaching</p><h2>From first model to student research</h2></div><p>A complete teaching portfolio connects course design, interactive mathematical models, Python laboratories, assessment, competition practice, and supervised research progression.</p></div><div class="actions"><a class="button" href="/teaching/">Explore teaching practice</a><a class="button secondary" href="/teaching/model-laboratory/">Try an interactive model</a></div></div></section>
  <section class="section"><div class="container"><div class="section-head"><div><p class="eyebrow">Selected writing</p><h2>Notes worth revisiting</h2></div><p>Representative tutorials and research notes, organized by purpose. The chronological archive remains available as secondary navigation.</p></div><div class="grid">{writing.slice(0,3).map(item=><article class="card"><p class="eyebrow">{item.data.type}</p><h3><a class="title-link" href={`/writing/${item.data.slug}/`}>{item.data.title}</a></h3><p>{item.data.summary}</p></article>)}</div></div></section>
</BaseLayout>
