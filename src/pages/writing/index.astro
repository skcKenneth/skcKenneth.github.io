---
import {getCollection} from "astro:content"; import BaseLayout from "../../layouts/BaseLayout.astro";
const all=(await getCollection("writing",({data})=>!data.draft&&data.slug!=="legacy-archive")).sort((a,b)=>(b.data.date?.valueOf()||0)-(a.data.date?.valueOf()||0)); const items=all.filter(x=>!x.data.archived); const archived=all.filter(x=>x.data.archived); const groups=Map.groupBy(items,x=>x.data.type);
---
<BaseLayout title="Writing" description="Research notes, technical tutorials, competition cases, teaching notes, mathematical curiosities, and migrated articles." type="Writing"><header class="page-head"><div class="container"><p class="eyebrow">Writing</p><h1>Ideas organized by what they help you do.</h1><p class="lead">Curated notes sit alongside {archived.length} complete articles migrated from the original Markdown archive.</p></div></header><section class="section"><div class="container">{[...groups].map(([type,entries])=><section style="margin-bottom:4rem"><h2>{type}</h2><div class="grid">{entries.map(entry=><article class="card wide"><p class="eyebrow">{entry.data.date?.getFullYear()}</p><h3><a class="title-link" href={`/writing/${entry.data.slug}/`}>{entry.data.title}</a></h3><p>{entry.data.summary}</p></article>)}</div></section>)}<section style="margin-bottom:4rem"><div class="section-head"><div><p class="eyebrow">Migrated Markdown</p><h2>Previously published articles</h2></div><p>The original article bodies, equations, code, and citations are preserved. Archive notices distinguish them from newly reviewed editorial work.</p></div><div class="grid">{archived.slice(0,6).map(entry=><article class="card wide"><p class="eyebrow">{entry.data.type} · {entry.data.date?.getFullYear()}</p><h3><a class="title-link" href={`/writing/${entry.data.slug}/`}>{entry.data.title}</a></h3><p>{entry.data.summary}</p></article>)}</div></section><div class="actions"><a class="button secondary" href="/writing/archive/">Browse all {all.length} articles</a></div></div></section></BaseLayout>
