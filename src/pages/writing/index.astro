---
import {getCollection} from "astro:content"; import BaseLayout from "../../layouts/BaseLayout.astro";
const items=(await getCollection("writing",({data})=>!data.draft&&!data.archived)).sort((a,b)=>(b.data.date?.valueOf()||0)-(a.data.date?.valueOf()||0)); const groups=Map.groupBy(items,x=>x.data.type);
---
<BaseLayout title="Writing" description="Research notes, technical tutorials, competition cases, teaching notes, mathematical curiosities, and archive." type="Writing"><header class="page-head"><div class="container"><p class="eyebrow">Writing</p><h1>Ideas organized by what they help you do.</h1><p class="lead">Representative notes are grouped by type. Chronology and preserved legacy material live in the archive.</p></div></header><section class="section"><div class="container">{[...groups].map(([type,entries])=><section style="margin-bottom:4rem"><h2>{type}</h2><div class="grid">{entries.map(entry=><article class="card wide"><p class="eyebrow">{entry.data.date?.getFullYear()}</p><h3><a class="title-link" href={`/writing/${entry.data.slug}/`}>{entry.data.title}</a></h3><p>{entry.data.summary}</p></article>)}</div></section>)}<div class="actions"><a class="button secondary" href="/writing/archive/">Browse chronological archive</a></div></div></section></BaseLayout>
