---
import {getCollection,render} from "astro:content"; import BaseLayout from "../../layouts/BaseLayout.astro"; import ArchiveNotice from "../../components/ArchiveNotice.astro"; import ReadingNav from "../../components/ReadingNav.astro"; import {publicRepositoryUrl} from "../../config/repository-policy"; import readingTime from "reading-time";
export async function getStaticPaths(){const items=(await getCollection("writing",({data})=>!data.draft)).filter(x=>x.data.slug!=="legacy-archive").sort((a,b)=>(a.data.date?.valueOf()||0)-(b.data.date?.valueOf()||0));return items.map((entry,i)=>({params:{slug:entry.data.slug},props:{entry,previous:items[i-1],next:items[i+1]}}));}
const {entry,previous,next}=Astro.props; const {Content}=await render(entry); const stats=readingTime(entry.body||"");
const links=[
  ["View calculations",publicRepositoryUrl(entry.data.technicalRepository),"button"],
  ["View notebooks",publicRepositoryUrl(entry.data.notebookUrl),"button secondary"],
  ["View source code",publicRepositoryUrl(entry.data.codeUrl),"button secondary"],
  ["Reproduce this study",publicRepositoryUrl(entry.data.reproductionUrl),"button secondary"]
].filter(([,href])=>href);
---
<BaseLayout title={entry.data.title} description={entry.data.summary} type="Writing"><header class="page-head"><div class="container"><p class="eyebrow">{entry.data.type}</p><h1>{entry.data.title}</h1><p class="lead">{entry.data.summary}</p><p class="small">{entry.data.date?.toLocaleDateString("en-GB",{dateStyle:"long"})} · {Math.max(1,Math.round(stats.minutes))} min read</p></div></header><div class="container content-shell"><aside><div class="tag-list">{entry.data.topics.map(t=><span class="tag">{t}</span>)}</div>{entry.data.scienceProject&&<p class="small">Evidence record<br/><strong>{entry.data.scienceProject}</strong><br/>Technical materials are maintained privately.</p>}{entry.data.legacySource&&<p class="small">Original Markdown<br/><code>{entry.data.legacySource}</code></p>}{links.length>0&&<div class="actions">{links.map(([label,href,className])=><a class={className} href={href}>{label}</a>)}</div>}</aside><article class="prose">{entry.data.archived&&<ArchiveNotice/>}<Content/><ReadingNav previous={previous&&{href:`/writing/${previous.data.slug}/`,title:previous.data.title}} next={next&&{href:`/writing/${next.data.slug}/`,title:next.data.title}}/></article></div></BaseLayout>
