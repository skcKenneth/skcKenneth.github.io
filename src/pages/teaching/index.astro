---
import { getCollection } from "astro:content"; import BaseLayout from "../../layouts/BaseLayout.astro";
const items=await getCollection("teaching",({data})=>!data.draft); const order={Beginner:0,Competition:1,Advanced:2,Instructor:3}; items.sort((a,b)=>order[a.data.level]-order[b.data.level]);
---
<BaseLayout title="Teaching" description="Mathematical modeling pathways, Python laboratories, competition preparation, student research, and instructor resources." type="Teaching"><header class="page-head"><div class="container"><p class="eyebrow">Teaching</p><h1>Learn modeling by making decisions visible.</h1><p class="lead">Choose a pathway by experience. Each connects mathematics, computation, validation, writing, and reproducibility.</p></div></header><section class="section"><div class="container grid">{items.map(item=><article class="card wide"><p class="eyebrow">{item.data.level} · {item.data.resourceType}</p><h2><a class="title-link" href={`/teaching/${item.data.slug}/`}>{item.data.title}</a></h2><p>{item.data.summary}</p></article>)}</div></section><section class="section"><div class="container section-head"><div><p class="eyebrow">Student research</p><h2>From case study to independent question</h2></div><p>Advanced students move from reproducing an existing result to changing one assumption, designing a check, and explaining what the new evidence supports. Suitable projects are marked in the <a href="/projects/?availability=student">project index</a>.</p></div></section></BaseLayout>
