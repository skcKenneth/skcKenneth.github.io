{
  "name": "kenneth-cheng-research-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/sync-science-projects.mjs && node scripts/migrate-legacy-writing.mjs && astro dev",
    "sync:science": "node scripts/sync-science-projects.mjs",
    "migrate:legacy": "node scripts/migrate-legacy-writing.mjs",
    "validate:content": "astro check",
    "check:redirects": "node scripts/check-redirects.mjs",
    "check:links": "node scripts/check-built-links.mjs",
    "check:output": "node scripts/check-output.mjs",
    "check:science": "node scripts/check-science-catalog.mjs",
    "check:legacy": "node scripts/check-legacy-writing.mjs",
    "check:writing-visuals": "node scripts/check-writing-visuals.mjs",
    "build:site": "astro build",
    "index:search": "pagefind --site dist",
    "build": "node scripts/sync-science-projects.mjs && node scripts/migrate-legacy-writing.mjs && astro check && astro build && pagefind --site dist && node scripts/check-science-catalog.mjs && node scripts/check-legacy-writing.mjs && node scripts/check-writing-visuals.mjs && node scripts/check-built-links.mjs && node scripts/check-output.mjs",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "7.0.2",
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.0.7",
    "katex": "0.17.0",
    "reading-time": "1.5.0",
    "rehype-katex": "7.0.1",
    "remark-math": "6.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "esbuild": "0.28.1",
    "pagefind": "1.5.2",
    "picomatch": "4.0.5",
    "typescript": "5.9.3",
    "vite": "8.0.14"
  }
}
